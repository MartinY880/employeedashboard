// ProConnect — MortgagePros Employee Portal
// Prisma Schema for PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ───────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  logtoId     String   @unique
  email       String   @unique
  displayName String
  role        Role     @default(EMPLOYEE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propsSent      PropsMessage[]  @relation("PropsAuthor")
  propsReceived  PropsMessage[]  @relation("PropsRecipient")
  propsReactions PropsReaction[]
  alertsCreated  Alert[]
  notifications  Notification[]

  mySharePosts        MySharePost[]        @relation("MyShareAuthor")
  myShareLikes        MyShareLike[]         @relation("MyShareLikes")
  myShareComments     MyShareComment[]      @relation("MyShareCommentAuthor")
  myShareCommentLikes MyShareCommentLike[]  @relation("MyShareCommentLikes")

  videoSpotlights         VideoSpotlight[]         @relation("VideoSpotlightAuthor")
  videoSpotlightReactions VideoSpotlightReaction[] @relation("VideoSpotlightReactionUser")
  videoSpotlightComments  VideoSpotlightComment[]  @relation("VideoSpotlightCommentAuthor")
  videoSpotlightCommentLikes VideoSpotlightCommentLike[] @relation("VideoSpotlightCommentLikeUser")

  propsComments          PropsComment[]           @relation("PropsCommentAuthor")
  propsCommentLikes       PropsCommentLike[]       @relation("PropsCommentLikeUser")

  ideas                  Idea[]                   @relation("IdeaAuthor")
  ideaComments           IdeaComment[]             @relation("IdeaCommentAuthor")
  ideaVotes              IdeaVote[]               @relation("IdeaVoteUser")
  ideaCommentLikes       IdeaCommentLike[]         @relation("IdeaCommentLikeUser")

  celebrationComments     CelebrationComment[]     @relation("CelebrationCommentAuthor")
  celebrationCommentLikes CelebrationCommentLike[] @relation("CelebrationCommentLikeUser")
  celebrationLikes        CelebrationLike[]        @relation("CelebrationLikeUser")

  @@map("users")
}

model PropsMessage {
  id          String   @id @default(cuid())
  content     String
  authorId    String   @map("user_id")
  recipientId String   @map("recipient_id")
  badge       String   @default("mvp")
  author      User     @relation("PropsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  recipient   User     @relation("PropsRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  reactions   PropsReaction[]
  comments    PropsComment[]
  createdAt   DateTime @default(now())

  @@index([authorId])
  @@index([recipientId])
  @@index([createdAt])
  @@map("props_messages")
}

model PropsReaction {
  id        String            @id @default(cuid())
  propsId   String            @map("props_id")
  userId    String            @map("user_id")
  reaction  PropsReactionType
  props     PropsMessage      @relation(fields: [propsId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@unique([propsId, userId])
  @@index([propsId, reaction])
  @@index([userId])
  @@map("props_reactions")
}

model PropsComment {
  id           String             @id @default(cuid())
  propsId      String
  authorId     String             @map("user_id")
  content      String
  parentId     String?
  likes        Int                @default(0)
  createdAt    DateTime           @default(now())
  props        PropsMessage       @relation(fields: [propsId], references: [id], onDelete: Cascade)
  author       User               @relation("PropsCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent       PropsComment?      @relation("PropsCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      PropsComment[]     @relation("PropsCommentReplies")
  likedBy      PropsCommentLike[]

  @@index([propsId, createdAt])
  @@index([parentId])
  @@index([authorId])
  @@map("props_comments")
}

model PropsCommentLike {
  id           String       @id @default(cuid())
  commentId    String
  userId       String       @map("user_id")
  createdAt    DateTime     @default(now())
  comment      PropsComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user         User         @relation("PropsCommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("props_comment_likes")
}

model Alert {
  id        String    @id @default(cuid())
  title     String
  content   String
  type      AlertType @default(INFO)
  priority  Priority  @default(LOW)
  active    Boolean   @default(true)
  expiresAt DateTime? @map("expires_at")
  createdBy String
  author    User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([active, priority])
  @@index([createdBy])
  @@index([expiresAt])
  @@map("alerts")
}

model Idea {
  id          String        @id @default(cuid())
  title       String
  description String
  userId      String        @map("user_id")
  votes       Int           @default(0)
  status      IdeaStatus    @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  author      User          @relation("IdeaAuthor", fields: [userId], references: [id], onDelete: Cascade)
  votesBy     IdeaVote[]
  comments    IdeaComment[]

  @@index([userId])
  @@index([status, votes])
  @@index([createdAt])
  @@map("ideas")
}

model IdeaVote {
  id           String        @id @default(cuid())
  ideaId       String
  userId       String        @map("user_id")
  direction    VoteDirection
  createdAt    DateTime      @default(now())
  idea         Idea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user         User          @relation("IdeaVoteUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
  @@index([userId])
  @@map("idea_votes")
}

model IdeaComment {
  id           String             @id @default(cuid())
  ideaId       String
  userId       String             @map("user_id")
  content      String
  parentId     String?
  likes        Int                @default(0)
  createdAt    DateTime           @default(now())
  idea         Idea               @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author       User               @relation("IdeaCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  parent       IdeaComment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      IdeaComment[]      @relation("CommentReplies")
  likedBy      IdeaCommentLike[]

  @@index([ideaId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("idea_comments")
}

model IdeaCommentLike {
  id           String      @id @default(cuid())
  commentId    String
  userId       String      @map("user_id")
  createdAt    DateTime    @default(now())
  comment      IdeaComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user         User        @relation("IdeaCommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("idea_comment_likes")
}

model QuickLink {
  id        String   @id @default(cuid())
  label     String
  url       String
  icon      String   @default("link")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@map("quick_links")
}

model EmployeeHighlight {
  id           String   @id @default(cuid())
  employeeId   String?
  employeeName String
  jobTitle     String?
  department   String?
  title        String
  subtitle     String
  avatarUrl    String?
  active       Boolean  @default(true)
  startDate    DateTime @default(now())
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, startDate])
  @@map("employee_highlights")
}

model SiteBranding {
  id           String   @id @default("singleton")
  companyName  String   @default("MortgagePros")
  logoData     String?  @db.Text // base64 data URL for logo image (light mode)
  darkLogoData String?  @db.Text @map("dark_logo_data") // base64 data URL for logo image (dark mode)
  faviconData  String?  @db.Text // base64 data URL for favicon
  updatedAt    DateTime @updatedAt

  @@map("site_branding")
}

model DirectorySnapshot {
  id                String   @id
  displayName       String   @map("display_name")
  mail              String?
  userPrincipalName String   @map("user_principal_name")
  jobTitle          String?  @map("job_title")
  employeeType      String?  @map("employee_type")
  department        String?
  officeLocation    String?  @map("office_location")
  managerId         String?  @map("manager_id")
  syncedAt          DateTime @default(now()) @map("synced_at")

  @@index([managerId])
  @@index([displayName])
  @@map("directory_snapshots")
}

model DirectorySnapshotState {
  id           String   @id
  lastSyncedAt DateTime? @map("last_synced_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("directory_snapshot_state")
}

// ─── Enums ────────────────────────────────────────────────

enum ForwardingStatus {
  PENDING    // Saved but not yet active (future start date)
  ACTIVE     // Forwarding rule currently enabled in Graph
  EXPIRED    // End date passed, rule removed
  CANCELLED  // User manually disabled
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum AlertType {
  INFO
  WARNING
  BIRTHDAY
  NEW_HIRE
  ANNOUNCEMENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IdeaStatus {
  ACTIVE
  SELECTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum VoteDirection {
  UP
  DOWN
}

enum TournamentStatus {
  SETUP
  IN_PROGRESS
  COMPLETED
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─── Notifications ────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  String?          @db.Text // JSON blob for extra context (link, sender, etc.)
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  PROPS     @map("KUDOS")
  HIGHLIGHT
  IDEA_SELECTED
  IDEA_IN_PROGRESS
  IDEA_COMPLETED
  IDEA_COMMENT
  IDEA_REPLY
  MYSHARE_COMMENT
  MYSHARE_REPLY
  CELEBRATION_COMMENT
  CELEBRATION_REPLY
  MENTION
}

enum PropsReactionType {
  HIGHFIVE
  UPLIFT
  BOMB

  @@map("PropsReactionType")
}

// ─── Calendar / Holidays ──────────────────────────────────

model Holiday {
  id        String   @id @default(cuid())
  title     String
  date      String   // Format: YYYY-MM-DD
  category  String   // federal, fun, company
  color     String   @default("#06427F")
  source    String   @default("custom") // custom, nager, calendarific, etc.
  visible   Boolean  @default(true)
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([visible])
  @@map("holidays")
}

model CalendarSyncLog {
  id       String   @id @default(cuid())
  source   String   // nager, calendarific, etc.
  status   String   // success, error
  message  String?
  syncedAt DateTime @default(now())

  @@index([syncedAt])
  @@map("calendar_sync_logs")
}

model CalendarSetting {
  id        String   @id @default("singleton")
  data      String   @default("{}") @db.Text // JSON blob for category labels, API configs, etc.
  updatedAt DateTime @updatedAt

  @@map("calendar_settings")
}

// ─── OOO Email Forwarding Schedule ────────────────────────

model ForwardingSchedule {
  id              String           @id @default(cuid())
  userEmail       String           // UPN / email of the mailbox owner
  forwardToEmail  String           // Where to forward
  forwardToName   String?          // Display name of recipient
  startsAt        DateTime         // When forwarding should activate
  endsAt          DateTime         // When forwarding should deactivate
  status          ForwardingStatus @default(PENDING)
  graphRuleId     String?          // ID of the Graph inbox rule (if created)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([userEmail, status])
  @@map("forwarding_schedules")
}

// ─── Tournament Bracket Models ────────────────────────────

model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?
  status      TournamentStatus @default(SETUP)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  teams   TournamentTeam[]
  matches TournamentMatch[]

  @@index([status])
  @@map("tournaments")
}

model TournamentTeam {
  id           String @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1Name  String
  player2Name  String
  seed         Int       @default(0)
  division     String    // "West", "East", "South", "Mid-West"
  createdAt    DateTime  @default(now())

  matchesAsTeam1 TournamentMatch[] @relation("MatchTeam1")
  matchesAsTeam2 TournamentMatch[] @relation("MatchTeam2")
  matchesWon     TournamentMatch[] @relation("MatchWinner")

  @@index([tournamentId, division])
  @@map("tournament_teams")
}

model TournamentMatch {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int         // 1 = first round, 2 = second round, etc.
  matchNumber  Int         // position within the round
  division     String      // "West", "East", "South", "Mid-West", "SemiFinal", "Final"
  team1Id      String?
  team1        TournamentTeam? @relation("MatchTeam1", fields: [team1Id], references: [id], onDelete: SetNull)
  team2Id      String?
  team2        TournamentTeam? @relation("MatchTeam2", fields: [team2Id], references: [id], onDelete: SetNull)
  winnerId     String?
  winner       TournamentTeam? @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  team1Score   Int?
  team2Score   Int?
  status       MatchStatus @default(PENDING)
  nextMatchId  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tournamentId, round, division])
  @@index([nextMatchId])
  @@map("tournament_matches")
}

// ─── Preferred Vendors ────────────────────────────────────

model PreferredVendor {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String   @default("General")
  contactName   String?  @map("contact_name")
  contactEmail  String?  @map("contact_email")
  contactPhone  String?  @map("contact_phone")
  contactPhoneLabel  String?  @map("contact_phone_label")   // e.g. "Cell", "Store", "Direct"
  secondaryPhone     String?  @map("secondary_phone")
  secondaryPhoneLabel String? @map("secondary_phone_label") // e.g. "Store", "Office"
  website       String?
  logoUrl       String?  @map("logo_url")
  iconId        String?  @map("icon_id")   // icon library id e.g. "lucide:building" used when no logo
  address       String?
  labels        String?  // comma-separated labels e.g. "Tailor, Jewelry"
  notes         String?  @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  active        Boolean  @default(true)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@index([category])
  @@index([featured])
  @@map("preferred_vendors")
}

// ─── Lenders ──────────────────────────────────────────────

model Lender {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?  @map("logo_url")
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accountExecutives LenderAccountExecutive[]

  @@map("lenders")
}

// ─── Lender Account Executives ───────────────────────────

model LenderAccountExecutive {
  id                   String   @id @default(cuid())
  lenderId             String   @map("lender_id")
  accountExecutiveName String   @map("account_executive_name")
  phoneNumber          String   @default("") @map("phone_number")
  workPhoneNumber      String   @default("") @map("work_phone_number")
  phoneExtension       String?  @map("phone_extension")
  mobilePhoneNumber    String?  @map("mobile_phone_number")
  email                String   @default("")
  active               Boolean  @default(true)
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  lender Lender @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  @@index([active, lenderId])
  @@index([lenderId, sortOrder])
  @@map("lender_account_executives")
}

// ─── Video Spotlight ──────────────────────────────────────

model VideoSpotlight {
  id          String   @id @default(cuid())
  title       String
  description String?
  filename    String               // stored filename on disk (uploads/videos/)
  mimeType    String   @default("video/webm")
  fileSize    Int      @default(0) // bytes
  duration    Float?               // seconds
  authorId    String?  @map("user_id") // FK to users.id
  author      User?    @relation("VideoSpotlightAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  featured    Boolean  @default(false)
  playCount   Int      @default(0)
  sortOrder   Int      @default(0)
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reactions    VideoSpotlightReaction[]
  comments     VideoSpotlightComment[]

  @@index([featured, status])
  @@index([createdAt])
  @@map("video_spotlights")
}

model VideoSpotlightReaction {
  id           String         @id @default(cuid())
  videoId      String
  userId       String         @map("user_id")
  type         String         // "like" | "dislike"
  createdAt    DateTime       @default(now())
  video        VideoSpotlight @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user         User           @relation("VideoSpotlightReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
  @@map("video_spotlight_reactions")
}

model VideoSpotlightComment {
  id           String                       @id @default(cuid())
  videoId      String
  authorId     String                       @map("user_id")
  content      String
  parentId     String?
  likes        Int                          @default(0)
  createdAt    DateTime                     @default(now())
  video        VideoSpotlight               @relation(fields: [videoId], references: [id], onDelete: Cascade)
  author       User                         @relation("VideoSpotlightCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent       VideoSpotlightComment?       @relation("VideoCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      VideoSpotlightComment[]      @relation("VideoCommentReplies")
  likedBy      VideoSpotlightCommentLike[]

  @@index([videoId, createdAt])
  @@index([parentId])
  @@map("video_spotlight_comments")
}

model VideoSpotlightCommentLike {
  id           String                @id @default(cuid())
  commentId    String
  userId       String                @map("user_id")
  createdAt    DateTime              @default(now())
  comment      VideoSpotlightComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user         User                  @relation("VideoSpotlightCommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("video_spotlight_comment_likes")
}

// ─── Important Dates ──────────────────────────────────────

model ImportantDate {
  id              String   @id @default(cuid())
  label           String
  subtitle        String?
  date            DateTime @db.Date
  recurType       String   @default("none")
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active, date])
  @@index([sortOrder])
  @@map("important_dates")
}

// ─── Closers Table Awards ─────────────────────────────────

model ClosersTableAward {
  id           String   @id @default(cuid())
  employeeId   String?  @map("employee_id")   // Microsoft Graph user ID
  employeeName String   @map("employee_name")
  award        String                          // e.g. "Top Closer Q1 2026"
  color        String   @default("#f59e0b")    // hex color for the card accent
  awardFontSize Int     @default(10) @map("award_font_size") // px size for award text
  sortOrder    Int      @default(0) @map("sort_order")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@map("closers_table_awards")
}

// Salesforce Comapny Directory Table 
model SalesforceDirectory {
  id                  String    @id
  email               String    @unique
  birthday            DateTime? @db.Date
  employmentStartDate DateTime? @db.Date @map("employment_start_date")
  syncedAt            DateTime  @default(now()) @map("synced_at")
  updatedAt           DateTime  @updatedAt

  examPassRecord    ExamPassRecord?
  celebrationEvents CelebrationEvent[]

  @@index([email])
  @@index([birthday])
  @@index([employmentStartDate])
  @@map("salesforce_directory")
}

// Salesforce Exam Passed 

model ExamPassRecord {
  id           String   @id @default(cuid())
  email        String   @unique
  employeeName String   @map("employee_name")
  createdAt    DateTime @default(now()) @map("created_at")

  employee     SalesforceDirectory @relation(fields: [email], references: [email])

  @@index([createdAt])
  @@map("exam_pass_records")
}

// ─── MyShare Posts (Social Feed) ──────────────────────────

model MySharePost {
  id        String    @id @default(cuid())
  authorId  String
  author    User      @relation("MyShareAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  caption   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @map("deleted_at")

  media     MyShareMedia[]
  likes     MyShareLike[]
  comments  MyShareComment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("myshare_posts")
}

model MyShareMedia {
  id        String      @id @default(cuid())
  postId    String
  post      MySharePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileUrl   String
  mimeType  String      @default("image/jpeg")
  fileSize  Int         @default(0)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([postId, sortOrder])
  @@map("myshare_media")
}

model MyShareLike {
  id        String      @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime    @default(now())
  post      MySharePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation("MyShareLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("myshare_likes")
}

model MyShareComment {
  id        String               @id @default(cuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime             @default(now())
  deletedAt DateTime?            @map("deleted_at")
  post      MySharePost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User                 @relation("MyShareCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    MyShareComment?      @relation("MyShareCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   MyShareComment[]     @relation("MyShareCommentReplies")
  likedBy   MyShareCommentLike[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([deletedAt])
  @@map("myshare_comments")
}

model MyShareCommentLike {
  id        String         @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime       @default(now())
  comment   MyShareComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User           @relation("MyShareCommentLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("myshare_comment_likes")
}

// ─── Role Mappings (job title → Logto role) ───────────────

model RoleMapping {
  id            String   @id @default(cuid())
  jobTitle      String   @unique @map("job_title")
  logtoRoleName String   @map("logto_role_name")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("role_mappings")
}

model RoleMappingExclusion {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String   @map("display_name")
  reason      String?
  createdAt   DateTime @default(now())

  @@map("role_mapping_exclusions")
}

// ─── Celebration Events & Comments ───────────────────────

model CelebrationEvent {
  id           String   @id @default(cuid())
  type         String
  email        String
  eventDate    DateTime @db.Date @map("event_date")
  employeeName String   @map("employee_name")
  detail       String
  commentCount Int      @default(0) @map("comment_count")
  likeCount    Int      @default(0) @map("like_count")
  createdAt    DateTime @default(now()) @map("created_at")

  employee     SalesforceDirectory @relation(fields: [email], references: [email], onDelete: Cascade)
  comments     CelebrationComment[]
  likes        CelebrationLike[]

  @@unique([type, email, eventDate])
  @@index([eventDate])
  @@map("celebration_events")
}

model CelebrationComment {
  id            String   @id @default(cuid())
  celebrationId String   @map("celebration_id")
  authorId      String   @map("author_id")
  content       String
  parentId      String?  @map("parent_id")
  likes         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  celebration   CelebrationEvent        @relation(fields: [celebrationId], references: [id], onDelete: Cascade)
  author        User                    @relation("CelebrationCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent        CelebrationComment?     @relation("CelebrationCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       CelebrationComment[]    @relation("CelebrationCommentReplies")
  likedBy       CelebrationCommentLike[]

  @@index([celebrationId, createdAt])
  @@index([parentId])
  @@map("celebration_comments")
}

model CelebrationCommentLike {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment   CelebrationComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User               @relation("CelebrationCommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("celebration_comment_likes")
}

model CelebrationLike {
  id             String   @id @default(cuid())
  celebrationId  String   @map("celebration_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  celebration    CelebrationEvent @relation(fields: [celebrationId], references: [id], onDelete: Cascade)
  user           User             @relation("CelebrationLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([celebrationId, userId])
  @@index([userId])
  @@map("celebration_likes")
}